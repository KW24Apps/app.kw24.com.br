# Arquivos de configuração local
config/local_config.php

# Logs locais
logs/*.log

# Arquivos temporários
*.tmp
*.cache

# Arquivos do sistema
.DS_Store
Thumbs.db

# Arquivos de IDE
.vscode/
.idea/

# Arquivos de sessão PHP
sessions/

# Backups
*.bak
*.backup

# Arquivos de ambiente local
.env
.env.local

# Pasta de contexto do projeto (documentação local — nunca vai pro servidor)
projeto/

# Python (relatorios-bi/)
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Script de teste local — roda o app sem o prefixo do nginx. NUNCA vai para produção.
relatorios-bi/*/run_local.py
# Túnel SSH local para o banco — contém credenciais. NUNCA vai para o repositório.
relatorios-bi/*/_tunnel.py

# Config de conexão gerado pelo painel (api/relatorio-conexao.php) — contém credenciais reais.
# Substitui o .env manual; NUNCA vai para o repositório.
.dbconfig.json

# Logos de clientes enviados via upload (Portal BI — relatorios_bi.logo_path / portais_bi.logo_path).
# Gerados em runtime pelo painel; NUNCA versionados — sobrevivem a deploys porque `git pull`
# nunca apaga arquivo não rastreado (mesmo princípio do .dbconfig.json acima).
assets/img/logos-clientes/
